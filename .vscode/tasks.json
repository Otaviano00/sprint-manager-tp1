{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run_c_debug",
      "type": "shell",
      "command": "python",
      "args": ["run.py", "-b", "-d"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Compila o projeto via CMake com flags de debug."
    },
    {
      "label": "run_c_full",
      "type": "shell",
      "command": "python",
      "args": ["run.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "focus": true,
        "echo": true,
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": ["$gcc"],
      "group": "build",
      "detail": "Compila e executa usando in.txt/out.txt."
    }
  ]
}
