{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "run_c_debug",
      "command": "../run.sh",
      "args": ["-f", "${fileDirname}/${fileBasename}", "-d"],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Task generated by Debugger."
    },
    {
      "type": "cppbuild",
      "label": "run_c",
      "command": "../run.sh",
      "args": ["-f", "${fileDirname}/${fileBasename}", "-i"],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Compile and run C program automatic"
    }
  ],
  "version": "2.0.0"
}
